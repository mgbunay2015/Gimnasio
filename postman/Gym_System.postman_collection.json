    {
      "name": "6 Escenarios de Prueba",
      "item": [
        {
          "name": "1 - MEMBER crea reserva (201 Created)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', function () { pm.response.to.have.status(201); });",
                  "var json = pm.response.json();",
                  "pm.test('memberUsername del token', function () { pm.expect(json.memberUsername).to.eql('member.test'); });",
                  "pm.test('RESERVED', function () { pm.expect(json.status).to.eql('RESERVED'); });",
                  "if (json.id) { pm.collectionVariables.set('bookingId', String(json.id)); }"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{memberToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
